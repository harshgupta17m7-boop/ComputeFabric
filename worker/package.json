{
  "name": "compute-worker",
  "version": "1.0.0",
  "description": "Worker daemon for ComputeFabric",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "build:cli": "npm run build && pkg . --targets node18-win-x64 --output compute-fabric-worker.exe"
  },
  "dependencies": {
    "os-utils": "^0.0.14",
    "socket.io-client": "^4.7.2",
    "systeminformation": "^5.31.7"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "@types/os-utils": "^0.0.4",
    "nodemon": "^3.0.1",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  },
  "pkg": {
    "scripts": "dist/**/*.js"
  }
}
